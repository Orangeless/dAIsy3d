{
  "name": "klaira",
  "version": "0.1.0",
  "private": true,
  "description": "Klaira — Proactive Ambient Anime AI Companion",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "concurrently \"electron-vite dev\" \"tsx watch server/index.ts\"",
    "build": "npm run build:server && electron-vite build",
    "build:server": "tsc --project server/tsconfig.json",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^2.1.0",
    "@pixiv/three-vrm-animation": "^2.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.164.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.164.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "build": {
    "appId": "com.klaira.desktop",
    "productName": "Klaira",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "dist/server",
        "to": "server"
      }
    ],
    "npmRebuild": false
  }
}
