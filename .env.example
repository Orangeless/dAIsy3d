# OpenRouter API Key (https://openrouter.ai)
# Used for AI model access. Primary model: deepseek/deepseek-v3
OPENROUTER_API_KEY=
# Optional: Override the AI model
# Default: deepseek/deepseek-v3
# Fast alt: meta-llama/llama-3.3-70b-instruct
AI_MODEL=deepseek/deepseek-v3

# Server port (default: 3847)
PORT=3847

# Data directory override (optional, defaults to system userData)
# KLAIRA_DATA_PATH=C:/Users/you/AppData/Roaming/klaira
